{
  "expo": {
    "name": "Machii",
    "slug": "machii",
    "owner": "wawooz",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "machii",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.machii.app",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Machii utilise ta position pour proposer les trajets proches de ton point de départ et sécuriser tes déplacements.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.machii.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBIQz8yKW6W-SsAsh-w9XIESXVG6P-pzFA"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#1B3D6E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B3D6E",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 100
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Machii utilise ta position pour proposer les trajets proches et sécuriser tes déplacements."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Machii accède à tes photos pour ta photo de profil et tes documents de vérification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-foreground.png",
          "color": "#1B3D6E"
        }
      ],
      "expo-secure-store",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "87d20ada-cd84-47f1-920c-6e2c44be4090"
      }
    }
  }
}
