# Machii — variables d'environnement (copie ce fichier en `.env`).
# Préfixe EXPO_PUBLIC_ = injecté dans le bundle au build (clés publiques uniquement).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

